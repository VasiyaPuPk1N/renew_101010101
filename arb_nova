import csv
import json
import logging
import os
import random
import time
from cryptography.fernet import Fernet
from eth_account import Account
from eth_utils import to_checksum_address
from web3 import Web3

# Настройка логирования (вывод в консоль и сохранение в файл истории сборов)
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.FileHandler("nova_aggregation.log", encoding="utf-8"),
        logging.StreamHandler()
    ]
)

# --- КОНФИГУРАЦИЯ ФАЙЛОВ И ЛИМИТОВ ---
ENCRYPTED_JSON_FILE = "encrypted_126.json" 
MIN_BALANCE_THRESHOLD = 0.001  # Проверять и собирать, если баланс больше 0.001 ETH

# Скоростные RPC-провайдеры для сети Arbitrum Nova со скриншота
rpc_providers = [
    "https://publicnode.com",
    "https://arbitrum.io"
]

current_rpc_index = 0
w3 = None

def init_web3(rpc_url):
    """Инициализация подключения к узлу Arbitrum Nova."""
    global w3
    w3 = Web3(Web3.HTTPProvider(rpc_url, request_kwargs={'timeout': 15}))

def switch_rpc():
    """Автоматическое переключение на резервную ноду при сбоях."""
    global current_rpc_index
    current_rpc_index = (current_rpc_index + 1) % len(rpc_providers)
    new_rpc = rpc_providers[current_rpc_index]
    logging.info(f"Переключаемся на резервный RPC Nova: {new_rpc}")
    init_web3(new_rpc)
    try:
        if w3.provider.is_connected(): return True
    except Exception:
        if w3.isConnected(): return True
    return False

# Первичное подключение к сети Arbitrum Nova
for rpc in rpc_providers:
    try:
        init_web3(rpc)
        connected = w3.provider.is_connected() if hasattr(w3.provider, 'is_connected') else w3.isConnected()
        if connected:
            logging.info(f"Успешно подключено к RPC Arbitrum Nova: {rpc}")
            break
    except Exception as e:
        logging.error(f"Не удалось подключиться к RPC {rpc}: {e}")
        continue

if w3 is None:
    logging.error("Критическая ошибка: Не удалось подключиться ни к одной ноде Arbitrum Nova!")
    exit(1)

def load_secure_keys_126():
    """Извлечение и дешифровка 126 ключей с помощью системной переменной '126'."""
    key_env = os.getenv('126')
    if key_env is None:
        logging.error("Критическая ошибка: В переменных среды не найден ключ шифрования '126'!")
        return []
        
    key_bytes = key_env.strip("b'").encode()
    cipher_suite = Fernet(key_bytes)
    
    try:
        with open(ENCRYPTED_JSON_FILE, 'rb') as file:
            encrypted_data = file.read()
        decrypted_data = cipher_suite.decrypt(encrypted_data)
        data = json.loads(decrypted_data)
        private_keys_raw = data['keys']
    except Exception as e:
        logging.error(f"Не удалось открыть или расшифровать файл {ENCRYPTED_JSON_FILE}: {e}")
        return []

    processed_accounts = []
    # Обрабатываем строго вашу базу из 126 кошельков
    for pk in private_keys_raw[:126]:
        key_cleaned = pk[2:] if pk.startswith('0x') else pk
        if len(key_cleaned) != 64: 
            continue
        try:
            account = Account.from_key(key_cleaned)
            # Сохраняем в список кортеж: (адрес, приватный ключ)
            processed_accounts.append((account.address.lower(), key_cleaned))
        except Exception:
            continue
            
    logging.info(f"Авторизация успешна. Извлечено и проверено {len(processed_accounts)} кошельков.")
    return processed_accounts
# --- ПРОДОЛЖЕНИЕ СКРИПТА (ЧАСТЬ 2) ---

def get_wallet_balance_eth(wallet_address):
    """Получает баланс кошелька в ETH с авто-переключением RPC при сбоях."""
    try:
        checksum_addr = to_checksum_address(wallet_address)
        # Получаем баланс кошелька в Wei
        balance_wei = w3.eth.get_balance(checksum_addr) if hasattr(w3.eth, 'get_balance') else w3.eth.getBalance(checksum_addr)
        # Переводим Wei в ETH
        return balance_wei / 10**18
    except Exception as e:
        logging.warning(f"Ошибка получения баланса для {wallet_address}: {e}. Пробуем резервный RPC...")
        switch_rpc()
        try:
            checksum_addr = to_checksum_address(wallet_address)
            balance_wei = w3.eth.get_balance(checksum_addr) if hasattr(w3.eth, 'get_balance') else w3.eth.getBalance(checksum_addr)
            return balance_wei / 10**18
        except Exception:
            return None

def calculate_tx_fees():
    """Рассчитывает лимиты и стоимость газа EIP-1559 в сети Arbitrum Nova."""
    try:
        # Получаем параметры последнего блока сети для расчета базовой комиссии
        latest_block = w3.eth.get_block('latest') if hasattr(w3.eth, 'get_block') else w3.eth.getBlock('latest')
        base_fee = latest_block['baseFeePerGas']
        
        # Получаем рекомендованную приоритетную комиссию (Max Priority Fee)
        max_priority_fee = w3.eth.max_priority_fee if hasattr(w3.eth, 'max_priority_fee') else w3.eth.maxPriorityFeePerGas
        
        # Рассчитываем максимальную стоимость газа с запасом 40% на колебания сети
        max_fee = int(base_fee * 1.4) + max_priority_fee
        
        # Стандартный лимит газа для пересылки ETH равен 21000
        gas_limit = 21000
        
        # Итоговая максимальная стоимость транзакции в Wei (лимит газа * максимальную цену)
        max_tx_cost_wei = max_fee * gas_limit
        
        return gas_limit, max_fee, max_priority_fee, max_tx_cost_wei
    except Exception as e:
        logging.error(f"Не удалось рассчитать параметры газа: {e}")
        switch_rpc()
        return None
# --- ПРОДОЛЖЕНИЕ СКРИПТА (ЧАСТЬ 3) ---

def send_nova_tx(sender_address, private_key, recipient_address, balance_eth):
    """Формирует, подписывает и отправляет транзакцию перевода ETH."""
    try:
        sender_checksum = to_checksum_address(sender_address)
        recipient_checksum = to_checksum_address(recipient_address)
        
        # Получаем параметры газа для транзакции
        fee_info = calculate_tx_fees()
        if not fee_info:
            logging.error(f"   Пропускаем кошелек {sender_address} из-за ошибки расчета газа.")
            return False
            
        gas_limit, max_fee, max_priority_fee, max_tx_cost_wei = fee_info
        
        # Переводим текущий баланс кошелька в Wei
        balance_wei = int(balance_eth * 10**18)
        
        # СУММА ОТПРАВКИ: вычитаем стоимость газа из баланса, чтобы забрать всё до единой Wei
        amount_to_send_wei = balance_wei - max_tx_cost_wei
        
        # Проверяем, что после вычета газа сумма остается положительной
        if amount_to_send_wei <= 0:
            logging.warning(f"   Баланса {balance_eth:.6f} ETH на {sender_address} не хватит на оплату газа.")
            return False
            
        # Получаем nonce кошелька
        nonce = w3.eth.get_transaction_count(sender_checksum) if hasattr(w3.eth, 'get_transaction_count') else w3.eth.getTransactionCount(sender_checksum)
        
        # Собираем структуру транзакции EIP-1559 под сеть Arbitrum Nova
        tx = {
            'from': sender_checksum,
            'to': recipient_checksum,
            'value': amount_to_send_wei,
            'gas': gas_limit,
            'maxFeePerGas': max_fee,
            'maxPriorityFeePerGas': max_priority_fee,
            'nonce': nonce,
            'chainId': 42170  # ChainID сети Arbitrum Nova со скриншота
        }
        
        # Авторизуем транзакцию приватным ключом текущего аккаунта
        signed_tx = w3.eth.account.sign_transaction(tx, private_key=private_key)
        
        # Отправляем сырые байты транзакции в мемпул сети Nova
        tx_hash = w3.eth.send_raw_transaction(signed_tx.rawTransaction) if hasattr(w3.eth, 'send_raw_transaction') else w3.eth.sendRawTransaction(signed_tx.rawTransaction)
        logging.info(f"   ➔ Транзакция отправлена! Сумма: {amount_to_send_wei / 10**18:.6f} ETH. Хэш: {w3.to_hex(tx_hash)}")
        
        # Ожидаем подтверждения транзакции сетью (около 2-4 секунд)
        receipt = w3.eth.wait_for_transaction_receipt(tx_hash, timeout=60) if hasattr(w3.eth, 'wait_for_transaction_receipt') else w3.eth.waitForTransactionReceipt(tx_hash, timeout=60)
        
        if receipt['status'] == 1:
            logging.info(f"   ✓ УСПЕШНО: Средства успешно доставлены на {recipient_address}!")
            return True
        else:
            logging.error(f"   ✗ СБОЙ: Блокчейн Nova отклонил выполнение транзакции.")
            return False
            
    except Exception as e:
        logging.error(f"   ✗ Критическая ошибка при отправке транзакции: {e}")
        switch_rpc()
        return False
# --- ПРОДОЛЖЕНИЕ СКРИПТА (ЧАСТЬ 4) ---

def main():
    # Загружаем безопасную карту аккаунтов (адрес, ключ)
    accounts = load_secure_keys_126()
    if not accounts:
        logging.error("Список аккаунтов пуст. Проверьте encrypted_126.json и переменную среды.")
        return

    total_wallets = len(accounts)
    logging.info(f"Запуск алгоритма последовательного сбора по цепочке для {total_wallets} кошельков.")
    logging.info(f"Направление сбора: от кошелька {total_wallets} к кошельку 1.")
    logging.info("=" * 80)

    # Проходим по цепочке в ОБРАТНОМ ПОРЯДКЕ: от последнего (индекс len-1) до второго кошелька (индекс 1)
    # Кошелек с индексом i будет переводить средства на кошелек с индексом i-1
    for i in range(total_wallets - 1, 0, -1):
        sender_address, sender_key = accounts[i]
        recipient_address, _ = accounts[i - 1]

        logging.info(f"[{total_wallets - i}/{total_wallets - 1}] Проверяем кошелек-отправитель #{i + 1}: {sender_address}")
        logging.info(f"   Целевой кошелек-получатель #{i}: {recipient_address}")

        # Проверяем текущий баланс отправителя в сети Arbitrum Nova
        balance = get_wallet_balance_eth(sender_address)
        
        if balance is None:
            logging.error(f"   Пропускаем шаг цепочки: не удалось получить баланс для {sender_address}")
            continue

        logging.info(f"   Текущий баланс: {balance:.6f} ETH")

        # ПРОВЕРКА ВАШЕГО УСЛОВИЯ: баланс должен быть строго больше 0.001 ETH
        if balance > MIN_BALANCE_THRESHOLD:
            logging.info(f"   🚀 Баланс выше лимита ({MIN_BALANCE_THRESHOLD} ETH). Начинаем сбор...")
            
            # Запускаем отправку транзакции
            success = send_nova_tx(sender_address, sender_key, recipient_address, balance)
            
            if not success:
                logging.warning(f"   ⚠️ Транзакция не прошла. Цепочка прервана на шаге {i + 1} -> {i}. Переходим к следующему.")
        else:
            logging.info(f"   Пропускаем сбор: баланс меньше или равен лимиту {MIN_BALANCE_THRESHOLD} ETH.")

        # Человеческая рандомная пауза (от 30 до 60 секунд) между шагами цепочки для безопасности
        if i > 1:
            sleep_time = random.randint(30, 60)
            logging.info(f"   Маскировка: Ожидаем {sleep_time} сек. перед проверкой следующего кошелька...")
            time.sleep(sleep_time)

    logging.info("=" * 80)
    logging.info("Процедура агрегации ETH по цепочке кошельков полностью завершена!")
    
    # Проверяем финальный баланс на главном кошельке #1
    final_main_addr = accounts[0][0]
    final_balance = get_wallet_balance_eth(final_main_addr)
    if final_balance is not None:
        logging.info(f"💰 Итоговый баланс на основном кошельке #1 ({final_main_addr}): {final_balance:.6f} ETH")
# --- ЗАВЕРШЕНИЕ СКРИПТА (ЧАСТЬ 5) ---

if __name__ == "__main__":
    logging.info("================================================================")
    logging.info("Скрипт агрегации ETH в сети Arbitrum Nova успешно запущен.")
    logging.info("================================================================")
    
    # Запускаем главную функцию последовательного сбора по цепочке
    main()
